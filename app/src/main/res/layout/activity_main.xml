<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clickable="true"
    android:focusable="true">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/videoLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/loadingBar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="visible" />

    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="16dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Center controls: 화면을 3등분 — 각 버튼이 33% 너비로 크게 표시 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/centerControls"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone">

        <!-- 수직 가이드라인: 33%, 67% 지점 -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.6" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.4" />

        <!-- 되감기: 화면 왼쪽 1/3 -->
        <ImageButton
            android:id="@+id/btnRewind"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideLeft"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_replay_10"
            android:scaleType="fitCenter"
            android:padding="0dp"
            android:tint="#FFFFFF"
            app:layout_constraintWidth_percent="0.05"
            android:contentDescription="10초 되감기" />

        <!-- 재생/일시정지: 화면 가운데 1/3 -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toEndOf="@id/guideLeft"
            app:layout_constraintEnd_toStartOf="@id/guideRight"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_pause"
            android:scaleType="fitCenter"
            android:padding="0dp"
            android:tint="#FFFFFF"
            app:layout_constraintWidth_percent="0.05"
            android:contentDescription="재생/일시정지" />

        <!-- 앞으로: 화면 오른쪽 1/3 -->
        <ImageButton
            android:id="@+id/btnFastForward"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toEndOf="@id/guideRight"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_forward_10"
            android:scaleType="fitCenter"
            android:padding="0dp"
            android:tint="#FFFFFF"
            app:layout_constraintWidth_percent="0.05"
            android:contentDescription="10초 앞으로" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Top bar: title + options — centerControls 뒤에 선언해야 터치 우선권 가짐 -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/top_gradient"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextClock
                android:id="@+id/tvClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format24Hour="yyyy.MM.dd  HH:mm"
                android:format12Hour="yyyy.MM.dd  a h:mm"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginEnd="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_star_yellow"
            android:scaleType="fitCenter"
            android:padding="8dp"
            android:contentDescription="즐겨찾기에 추가" />

        <TextView
            android:id="@+id/btnSpeed"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_speed_pill"
            android:gravity="center"
            android:minWidth="52dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="1.0×"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:contentDescription="재생 속도" />

        <ImageButton
            android:id="@+id/btnRotationLock"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_blue_circle"
            android:src="@drawable/ic_rotation"
            android:contentDescription="회전 잠금" />

        <ImageButton
            android:id="@+id/btnOptions"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:background="@drawable/bg_red_circle"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#FFFFFF"
            android:contentDescription="옵션" />
    </LinearLayout>

    <!-- Floating Back 버튼 — 컨트롤과 함께 토글, 우하단 고정 -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="120dp"
        android:background="@drawable/bg_red_circle"
        android:src="@drawable/ic_back"
        android:contentDescription="뒤로가기"
        android:visibility="gone" />

    <!-- Bottom controls -->
    <LinearLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/controls_gradient"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF" />

        <!-- prev(1/5) ... next(4/5) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="8dp">

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_previous"
                android:tint="#FFFFFF"
                android:visibility="gone"
                android:contentDescription="이전 영상" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="3" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                android:tint="#FFFFFF"
                android:visibility="gone"
                android:contentDescription="다음 영상" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
