<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 타이틀 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAS 설정"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Synology NAS 접속 정보를 입력하세요."
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- NAS 주소 (외부/QuickConnect) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAS 주소 (외부)"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://xxxx.quickconnect.to"
            android:inputType="textUri"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <!-- LAN 주소 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAN 주소 (선택 — 같은 네트워크일 때 빠른 연결)"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etLanUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.x.x:5000"
            android:inputType="textUri"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <!-- 아이디 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="아이디"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="username"
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <!-- 비밀번호 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="비밀번호"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <EditText
                android:id="@+id/etPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="password"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:paddingEnd="48dp" />

            <ImageButton
                android:id="@+id/btnTogglePass"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#888888"
                android:contentDescription="비밀번호 표시/숨기기" />
        </FrameLayout>

        <!-- 고급 설정 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A3A3A"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="고급 설정 (선택)"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <!-- 기본 탐색 경로 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="기본 탐색 경로"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etBasePath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <!-- 위치 저장 폴더 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="위치 저장 폴더"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etPosDir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="32dp" />

        <!-- 연결 테스트 버튼 -->
        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="연결 테스트"
            android:backgroundTint="#4A90D9"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- 결과 메시지 -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 저장 버튼 (연결 성공 후 활성화) -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="저장"
            android:backgroundTint="#2ECC71"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:alpha="0.5" />

    </LinearLayout>

</ScrollView>
